# Прод-конфиг StaffSwipe (docker-compose.prod.yml).
# Скопируйте:  cp .env.example .env   и заполните значения.
# Секреты сгенерируйте:  bash scripts/gen-secrets.sh

# --- ОБЯЗАТЕЛЬНО ---

# Домен, на котором висит Mini App (без https://). DNS A-запись → IP сервера.
DOMAIN=app.example.ru

# Токен бота из @BotFather.
TELEGRAM_BOT_TOKEN=

# Username бота без @ (для реферальных ссылок t.me/<bot>?startapp=...).
BOT_USERNAME=staffswipe_bot

# Пароль БД — придумайте длинный случайный (gen-secrets.sh подскажет).
POSTGRES_PASSWORD=

# Секрет подписи JWT — случайный, длинный.
JWT_SECRET=

# Секрет для внутренних вызовов (бот/вебхук → /billing/fulfill) — случайный.
INTERNAL_API_SECRET=

# --- ЮРИДИЧЕСКОЕ (нужно на публичный запуск, 152-ФЗ) ---
# Ссылки на оферту и политику обработки ПДн (опубликуйте docs/legal/*).
VITE_OFFER_URL=
VITE_PRIVACY_URL=
# Ссылка на поддержку (Telegram-чат/бот) — раздел «Помощь».
VITE_SUPPORT_URL=

# --- ОПЦИОНАЛЬНО (можно оставить пустым на пилоте) ---
# Telegram-id админов через запятую — доступ к аналитике воронки.
ADMIN_TG_IDS=

# DaData — проверка ИНН/ОГРН заведений.
DADATA_TOKEN=
DADATA_SECRET=

# S3-хранилище фото (напр. Yandex Object Storage). Без ключей загрузка фото
# отдаёт 503, остальное работает.
S3_ENDPOINT=
S3_BUCKET=
S3_KEY=
S3_SECRET=
S3_PUBLIC_BASE=

# Sentry DSN для наблюдаемости ошибок.
SENTRY_DSN=
