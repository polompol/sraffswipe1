# Базовый URL backend (FastAPI)
VITE_API_BASE_URL=http://localhost:8000

# true — ходить в реальный backend; пусто/false — работать на mock-данных
VITE_USE_BACKEND=false

# ОБЯЗАТЕЛЬНО перед запуском: ссылки на оферту и политику обработки ПДн (152-ФЗ).
# Опубликуйте документы из docs/legal/ (напр. на Telegra.ph или своём сайте).
VITE_OFFER_URL=
VITE_PRIVACY_URL=

# Только для локальной отладки вне Telegram: сырой initData
# VITE_DEV_INIT_DATA=

# Наблюдаемость (опц.): Sentry DSN для @sentry/react
# VITE_SENTRY_DSN=

# Ссылка на поддержку (Telegram-чат/бот) — показывается в разделе «Помощь»
VITE_SUPPORT_URL=
