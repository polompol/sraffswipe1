# Скопируйте в .env и заполните.

# БД: по умолчанию SQLite (без зависимостей). Для прода — PostgreSQL/PostGIS:
# DATABASE_URL=postgresql+psycopg://staffswipe:staffswipe@localhost:5432/staffswipe
DATABASE_URL=sqlite:///./staffswipe.db

JWT_SECRET=change-me-in-prod
JWT_ALG=HS256
JWT_TTL_HOURS=720

# В dev_mode код из SMS возвращается в ответе /auth/request-code.
DEV_MODE=true

# SMS-шлюз: none|exolve|smsru|smsc
SMS_PROVIDER=none
SMS_API_KEY=

# DaData — проверка ИНН/ОГРН и адресов.
DADATA_TOKEN=
DADATA_SECRET=

# --- Telegram Mini App ---
# Токен бота из @BotFather (валидация initData + платежи Stars).
TELEGRAM_BOT_TOKEN=
# Публичный HTTPS-URL Mini App.
MINI_APP_URL=
# true — пускать без валидной подписи initData (ТОЛЬКО для локальной отладки).
ALLOW_INSECURE_TELEGRAM_AUTH=true

# --- Платежи ЮKassa (рубли) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
PAYMENT_RETURN_URL=
