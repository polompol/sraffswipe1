# Скопируйте в .env и заполните.

# БД: по умолчанию SQLite (без зависимостей). Для прода — PostgreSQL/PostGIS:
# DATABASE_URL=postgresql+psycopg://staffswipe:staffswipe@localhost:5432/staffswipe
DATABASE_URL=sqlite:///./staffswipe.db

JWT_SECRET=change-me-in-prod
JWT_ALG=HS256
JWT_TTL_HOURS=720

# В dev_mode код из SMS возвращается в ответе /auth/request-code.
DEV_MODE=true

# SMS-шлюз: none|exolve|smsru|smsc
SMS_PROVIDER=none
SMS_API_KEY=

# DaData — проверка ИНН/ОГРН и адресов.
DADATA_TOKEN=
DADATA_SECRET=

# --- Telegram Mini App ---
# Токен бота из @BotFather (валидация initData + платежи Stars).
TELEGRAM_BOT_TOKEN=
# Публичный HTTPS-URL Mini App.
MINI_APP_URL=
# Username бота (без @) — для реферальных ссылок t.me/<bot>?startapp=ref_<id>.
BOT_USERNAME=staffswipe_bot
# true — пускать без валидной подписи initData (ТОЛЬКО для локальной отладки).
# В ПРОДЕ обязательно false.
ALLOW_INSECURE_TELEGRAM_AUTH=false

# Секрет для внутренних вызовов бот/вебхук → /billing/fulfill. Задайте случайным.
INTERNAL_API_SECRET=
# Отдельный секрет для вебхука ЮKassa (рекомендуется): утечка URL из логов не
# откроет /fulfill. Пусто → используется INTERNAL_API_SECRET.
YOOKASSA_WEBHOOK_SECRET=

# Разрешённые источники CORS (csv). Пусто + DEV_MODE=true → "*". В проде — URL Mini App.
ALLOWED_ORIGINS=

# --- Платежи ЮKassa (рубли) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
PAYMENT_RETURN_URL=
# 54-ФЗ: слать фискальный чек. Включать ТОЛЬКО если касса не фискализирует сама
# (уточнить у бухгалтера). vat_code: 1 — без НДС (самозанятый/УСН), 6 — НДС 20%.
YOOKASSA_SEND_RECEIPT=false
YOOKASSA_VAT_CODE=1

# --- Хранилище фото (S3-совместимое, напр. Yandex Object Storage) ---
# Без ключей загрузка фото отдаёт 503 (остальное работает).
S3_ENDPOINT=
S3_BUCKET=
S3_KEY=
S3_SECRET=
S3_PUBLIC_BASE=

# Telegram-id админов (csv) — доступ к админ-панели и аналитике.
# Уже вписан id владельца проекта.
ADMIN_TG_IDS=7833280774

# Бонус рефереру за приглашённого (супер-лайки).
REFERRAL_BONUS_SUPERLIKES=3

# Наблюдаемость (опц.): Sentry DSN. Требует установленного sentry-sdk.
SENTRY_DSN=
